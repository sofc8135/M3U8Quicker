{
  "manifest_version": 2,
  "name": "m3u8quicker Detector",
  "version": "1.0.0",
  "description": "Detect m3u8 resources on the page and show a quick download button.",
  "icons": {
    "128": "icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "m3u8quicker@example.com",
      "strict_min_version": "57.0"
    }
  },
  "permissions": [
    "webRequest",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    "injected-network.js",
    "icon.png"
  ]
}
